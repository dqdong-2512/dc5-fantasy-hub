root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,md}]
indent_size = 2
indent_style = space

[*.{ts,tsx,js,jsx}]
indent_size = 2
indent_style = space

[*.md]
max_line_length = off
trim_trailing_whitespace = false

end_of_line = lf
