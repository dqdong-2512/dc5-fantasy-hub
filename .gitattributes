###############################################################################
# Default
###############################################################################

* text=auto eol=lf

###############################################################################
# Source Code
###############################################################################

*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf

###############################################################################
# Windows Scripts
###############################################################################

*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

###############################################################################
# Binary
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text